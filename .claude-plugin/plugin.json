{
  "name": "ds-mode",
  "version": "1.4.0",
  "description": "Plain-English TLDR + visual HTML one-pager for non-trivial Claude Code replies. Modes: lite (TLDR only) | full (TLDR + auto HTML, default) | off. /ds-mode <prompt> forces the visual one-pager in any mode.",
  "author": {
    "name": "Nathan Hekman",
    "url": "https://github.com/nathan-hekman"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/ds-mode-activate.js\"",
            "timeout": 5,
            "statusMessage": "Loading DS Mode..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/ds-mode-tracker.js\"",
            "timeout": 5,
            "statusMessage": "Tracking DS Mode..."
          }
        ]
      }
    ]
  }
}
